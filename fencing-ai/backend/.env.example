# ── Provider selection ────────────────────────────────────────────────────────
# Choose one: anthropic (default) | openrouter | nvidia | ollama
ANALYZER_PROVIDER=anthropic

# ── API keys — only the key for your chosen provider is required ──────────────

# Anthropic (Claude) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenRouter — https://openrouter.ai/keys  (free models available)
# OPENROUTER_API_KEY=your_openrouter_key_here

# NVIDIA NIM — https://build.nvidia.com  (free tier, no CC required)
# NVIDIA_API_KEY=your_nvidia_api_key_here

# Ollama — local AI: 100% free, no rate limits, no API key. Runs on your own
# machine (install from https://ollama.com). Optionally point at a non-default
# host with OLLAMA_HOST (default http://localhost:11434).
# ANALYZER_PROVIDER=ollama
# OLLAMA_HOST=http://localhost:11434

# ── Model override (optional) ─────────────────────────────────────────────────
# Defaults per provider:
#   anthropic:  claude-haiku-4-5-20251001
#   openrouter: meta-llama/llama-3.2-11b-vision-instruct:free
#   nvidia:     meta/llama-3.2-11b-vision-instruct
#   ollama:     llama3.2-vision
# ANALYZER_MODEL=llama3.2-vision
