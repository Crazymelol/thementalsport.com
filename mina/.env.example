# Mina's brain runs on Groq (free, fast). Get a key at https://console.groq.com
# (Sign in → API Keys → Create API Key). It starts with gsk_...
GROQ_API_KEY=gsk_...

# --- Gmail (optional) ---
# Lets Mina read/search your inbox and send email (sending stays behind the
# approval gate). Uses a Gmail "App Password", NOT your normal password:
#   1. Turn on 2-Step Verification: https://myaccount.google.com/security
#   2. Create an app password: https://myaccount.google.com/apppasswords
# Leave these blank and Mina falls back to sample inbox data.
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
